# ============================================================
# UPZY — Variables de Entorno
# Copia este archivo a .env y completa los valores
# NUNCA subas .env a GitHub — solo este .env.example
# ============================================================

# ── TENANT ───────────────────────────────────────────────────
# Identificador único del tenant en esta instancia
# En el piloto Klinge = 'klinge'. En producción multi-tenant
# esto viene de la BD o del subdominio.
TENANT_ID=klinge

# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# URL pública del servidor (Railway la asigna automáticamente)
BASE_URL=https://lumi-klinge-bot-production.up.railway.app

# ── SUPABASE ─────────────────────────────────────────────────
# URL del proyecto Supabase
SUPABASE_URL=https://nikmfrlvhmnjtwctwmid.supabase.co

# Clave anónima — solo para operaciones públicas (NO usar en backend)
SUPABASE_ANON_KEY=

# Clave service role — USAR SIEMPRE en el backend (bypasa RLS)
# Obtener en: Supabase > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── ANTHROPIC / CLAUDE ───────────────────────────────────────
# API Key de Anthropic para el motor IA de Lumi
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Modelo a usar (no cambiar sin probar)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── WHATSAPP — EVOLUTION API ─────────────────────────────────
# URL base de tu instancia de Evolution API
EVOLUTION_API_URL=

# API Key global de Evolution
EVOLUTION_API_KEY=

# Nombre de la instancia WA configurada en Evolution
EVOLUTION_INSTANCE=

# ── INSTAGRAM — META GRAPH API ───────────────────────────────
# Token de acceso de larga duración de la página/cuenta IG
# Renovar antes de que expire (cada 60 días si es corta duración)
IG_ACCESS_TOKEN=

# ID de la página de Facebook vinculada a la cuenta IG Business
IG_PAGE_ID=

# ID de la cuenta de Instagram Business
# Klinge: 17841401601485577
IG_BUSINESS_ACCOUNT_ID=17841401601485577

# Username de la cuenta IG (solo referencia, no lo usa el código)
IG_USERNAME=klinge.cl

# Token de verificación para el webhook de Meta
# Puedes poner cualquier string — debe coincidir con el configurado en Meta Developers
IG_VERIFY_TOKEN=

# ── SHOPIFY ──────────────────────────────────────────────────
# Dominio de la tienda Shopify
SHOPIFY_DOMAIN=klingecl.myshopify.com

# Secret del webhook — se usa para verificar la firma HMAC
# Obtener en: Shopify Admin > Settings > Notifications > Webhooks
SHOPIFY_WEBHOOK_SECRET=

# API Key y Access Token de la app Shopify (si usas Admin API)
SHOPIFY_API_KEY=
SHOPIFY_ACCESS_TOKEN=

# ── ELEVENLABS ───────────────────────────────────────────────
# API Key para síntesis de voz de Lumi
ELEVENLABS_API_KEY=

# ID de la voz configurada para Lumi
ELEVENLABS_VOICE_ID=

# ── EMAIL — RESEND (a implementar en Fase 3) ─────────────────
# API Key de Resend para envío transaccional y campañas
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=

# Email remitente verificado en Resend
RESEND_FROM_EMAIL=hola@upzy.app

# ── NOTIFICACIONES INTERNAS (opcional) ───────────────────────
# Webhook de Slack o Discord para alertas internas del sistema
INTERNAL_WEBHOOK_URL=

# ============================================================
# NOTAS DE SEGURIDAD
# ============================================================
# 1. En Railway: configurar cada variable en
#    Project > Variables (NO en el código)
# 2. Nunca loggear process.env en producción
# 3. Rotar SUPABASE_SERVICE_ROLE_KEY si se compromete
# 4. IG_ACCESS_TOKEN expira — configurar alerta de renovación
# ============================================================
